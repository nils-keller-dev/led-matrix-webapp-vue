{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"],
  "compilerOptions": {
    "lib": ["dom", "ESNext"],
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["node"]
  },
  "vueCompilerOptions": {
    "checkUnknownComponents": true
  }
}
